# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — get from resend.com dashboard → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Health Bridge Solution <report@healthbridgesolution.my>

# Anthropic — get from console.anthropic.com → API Keys
# Used to automatically read uploaded lab report PDFs/images and extract
# marker values, instead of requiring manual entry.
ANTHROPIC_API_KEY=
