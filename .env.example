# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (Settings → API → service_role, "secret"). Used server-side
# only, bypasses Row Level Security. Never expose this to the browser or
# prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — get from resend.com dashboard → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Health Bridge Solution <report@healthbridgesolution.my>

# Anthropic — get from console.anthropic.com → API Keys
# Used to automatically read uploaded lab report PDFs/images and extract
# marker values, instead of requiring manual entry.
ANTHROPIC_API_KEY=

# Billplz — Malaysian payment gateway (billplz.com). Get from your Billplz
# dashboard → Settings → API. Used to charge RM 49 per report ("pay to
# unlock delivery": customer pays after review, before receiving the PDF).
# Set BILLPLZ_SANDBOX=false only when ready to go live with real payments.
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE_KEY=
BILLPLZ_SANDBOX=true
